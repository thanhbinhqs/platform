# ─── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=api
API_VERSION=1
APP_NAME=Platform

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:***@localhost:5432/platform

# ─── Valkey (Redis) ───────────────────────────────────────
VALKEY_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars-!!
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Encryption ────────────────────────────────────────────
ENCRYPTION_KEY=change-me-32-char-minimum-key-here

# ─── Storage (S3/MinIO) ────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_BUCKET=platform
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=*

# ─── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── MQTT ──────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=platform/

# ─── OpenTelemetry ─────────────────────────────────────────
OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=platform-api
ENABLE_METRICS=false

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ─── SMTP ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@platform.local
